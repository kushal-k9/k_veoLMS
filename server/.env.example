# ===== Server / Express =====
NODE_ENV=development
PORT=4000
# Set to true only when running behind a reverse proxy (nginx, Heroku, etc.)
TRUST_PROXY=false
# Frontend origin allowed by CORS (must match the running frontend dev server)
CLIENT_ORIGIN=http://localhost:8080

# ===== Database =====
MONGODB_URI=mongodb://127.0.0.1:27017/veolms

# ===== Cookie / Session signing =====
# Use long random strings. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=change-me-to-a-long-random-string
CSRF_SECRET=change-me-to-a-long-random-string

# ===== JWT =====
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ===== Password hashing =====
BCRYPT_ROUNDS=12

# ===== Google OAuth (optional — leave blank to disable Google sign-in) =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ===== Stripe =====
STRIPE_SECRET_KEY=sk_test_xxx
# From `stripe listen` (CLI) or the dashboard webhook settings. Optional in dev.
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# ===== Email / SMTP (optional — OTP codes log to console if unset) =====
EMAIL_HOST=
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=VeoLMS <noreply@veolms.com>

# ===== Limits =====
JSON_BODY_LIMIT=10kb
UPLOAD_MAX_BYTES=2097152
